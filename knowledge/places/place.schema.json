{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge/places/place.schema.json",
  "title": "India project place record",
  "type": "object",
  "required": [
    "place_id",
    "canonical_name",
    "aliases",
    "place_type",
    "coordinates",
    "coordinate_accuracy",
    "clusters",
    "formal_status",
    "status_decision_id",
    "document_status",
    "overlays",
    "last_content_verified_at",
    "last_practical_verified_at",
    "legacy_references",
    "record_status"
  ],
  "properties": {
    "place_id": {"type": "string", "pattern": "^IND-PLACE-[0-9]{6}$"},
    "canonical_name": {"type": "string", "minLength": 1},
    "aliases": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "place_type": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "coordinates": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["lat", "lon"],
          "properties": {
            "lat": {"type": "number", "minimum": -90, "maximum": 90},
            "lon": {"type": "number", "minimum": -180, "maximum": 180}
          },
          "additionalProperties": false
        }
      ]
    },
    "coordinate_accuracy": {"enum": ["EXACT", "ENTRANCE", "COMPLEX", "APPROXIMATE", "NOT_ESTABLISHED"]},
    "clusters": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "formal_status": {"enum": ["A", "B", "C", "U"]},
    "status_decision_id": {"type": ["string", "null"], "pattern": "^DECISION-[0-9]{4}$"},
    "document_status": {"enum": ["SEED", "BRONS", "ZILVER", "GOUD", "DECISION_READY", "COMPLETE"]},
    "overlays": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "last_content_verified_at": {"type": ["string", "null"], "format": "date"},
    "last_practical_verified_at": {"type": ["string", "null"], "format": "date"},
    "legacy_references": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "record_status": {"enum": ["ACTIVE", "MERGED", "RETIRED"]},
    "merged_into": {"type": ["string", "null"], "pattern": "^IND-PLACE-[0-9]{6}$"}
  },
  "additionalProperties": true
}
